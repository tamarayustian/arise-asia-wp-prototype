---
import PostCard from "@/components/shared/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE_NAME } from "@/lib/constants";
import { getPosts } from "@/lib/services/posts";
import { ActionButton } from "@/components/shared/ActionButton";
import SimpleButton from "@/components/shared/SimpleButton.astro";
import AnimatedCounter from "@/components/shared/AnimatedCounter.astro";
import { ArrowRight } from "lucide-react";

const { locale } = Astro.params;
const posts = await getPosts(locale);
const countries = 12;
const cities = 40;
const participants = 12345;
const commitments = 7890;
---

<Layout title={SITE_NAME} locale={locale!}>
  <header>
    <div class="container mx-auto px-8 pt-40 sm:pt-48">
      <!-- Mobile layout (below md) -->
      <div class="flex flex-col md:hidden">
        <p
          class="font-heading w-fit bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-2xl font-semibold tracking-wider text-nowrap text-transparent uppercase"
        >
          Arise Asia 2026
        </p>
        <div class="flex items-start justify-center">
          <h1
            class="font-heading bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-6xl font-bold text-transparent uppercase sm:text-7xl"
          >
            <span class="block">For</span>
            <span class="block">The</span>
          </h1>
          <img alt="Joy" class="w-56 shrink-0" src="/joy.svg" />
        </div>
        <div
          class="font-heading flex justify-between text-xs font-bold uppercase sm:text-base"
        >
          <p
            class="bg-linear-to-r from-[#2563eb] to-[#3172f0] bg-clip-text text-nowrap text-transparent"
          >
            27-31 July
          </p>
          <p
            class="bg-linear-to-r from-[#3172f0] to-[#3b82f6] bg-clip-text text-nowrap text-transparent"
          >
            Manila, Philippines
          </p>
        </div>
      </div>
      <!-- Desktop layout (md+) -->
      <div
        class="hidden md:flex md:items-center md:justify-center md:gap-x-6 lg:items-center lg:justify-center"
      >
        <div class="w-fit">
          <p
            class="font-heading w-fit bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-2xl font-semibold tracking-wider text-nowrap text-transparent uppercase md:text-3xl lg:text-4xl"
          >
            Arise Asia 2026
          </p>
          <h1
            class="font-heading bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-6xl font-bold text-transparent uppercase sm:text-6xl md:text-7xl md:text-nowrap lg:text-8xl xl:text-9xl"
          >
            For The
          </h1>
          <div
            class="font-heading flex justify-between text-base font-bold uppercase lg:text-xl"
          >
            <p
              class="bg-linear-to-r from-[#2563eb] to-[#3172f0] bg-clip-text text-nowrap text-transparent"
            >
              27-31 July
            </p>
            <p
              class="bg-linear-to-r from-[#3172f0] to-[#3b82f6] bg-clip-text text-nowrap text-transparent"
            >
              Manila, Philippines
            </p>
          </div>
        </div>
        <div class="relative">
          <img
            alt="Joy"
            class="md:mt-10 md:w-80 lg:mt-10 xl:w-96"
            src="/joy.svg"
          />
        </div>
      </div>
      <div class="mx-auto mt-5 mb-10 flex flex-col items-center xl:mb-12">
        <p
          class="font-heading text-h4 mt-2 font-medium text-[#2b2b2b] uppercase"
        >
          is happening in...
        </p>
        <div class="flex items-center gap-x-2 sm:mt-6 sm:gap-x-6 md:gap-x-10">
          <div class="flex flex-col items-center">
            <p id="countdown-days" class="text-h2 lg:text-h1 text-blue-900">
              00
            </p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Days
            </p>
          </div>
          <p class="text-h3 text-neutral-500">:</p>
          <div class="flex flex-col items-center">
            <p id="countdown-hours" class="text-h2 lg:text-h1 text-blue-900">
              00
            </p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Hours
            </p>
          </div>
          <p class="text-h3 text-neutral-500">:</p>
          <div class="flex flex-col items-center">
            <p id="countdown-minutes" class="text-h2 lg:text-h1 text-blue-900">
              00
            </p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Minutes
            </p>
          </div>
          <p class="text-h3 text-neutral-500">:</p>
          <div class="flex flex-col items-center">
            <p id="countdown-seconds" class="text-h2 lg:text-h1 text-blue-900">
              00
            </p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Seconds
            </p>
          </div>
        </div>
        <ActionButton className="mt-10" href="/arise26"
          >Learn more now</ActionButton
        >
      </div>
    </div>
  </header>

  <div
    class="from-accent-orange-lightest bg-linear-to-b to-white px-8 md:px-16 lg:px-48"
  >
    <section id="vision" class="flex flex-col items-center pt-10">
      <div class="flex items-end pb-5">
        <img
          alt="Arise logo - black font"
          class="size-16 sm:size-24 md:size-28"
          src="/logo-black-font.svg"
        />
        <p
          class="font-heading -mb-1.5 -ml-2.5 text-2xl font-medium whitespace-nowrap uppercase sm:-ml-4 sm:text-4xl md:text-5xl"
        >
          rise Asia
        </p>
      </div>
      <p class="font-heading pb-2 text-center text-xl md:text-3xl">
        By 2033, our goal is that 100,000 young people from 500 cities and 50
        countries in Asia and beyond will receive the challenge to
      </p>
      <p
        class="font-heading bg-[linear-gradient(90deg,#FE5F5B_0%,#FFA45B_100%)] bg-clip-text text-center text-3xl font-semibold text-transparent uppercase sm:text-4xl md:text-5xl lg:text-6xl"
      >
        Go where there is no Gospel
      </p>
    </section>

    <section id="impact" class="flex flex-col items-center pt-20">
      <h2 class="text-h3 font-heading font-normal uppercase">
        Our Impact To-Date
      </h2>
      <div
        class="grid w-full grid-cols-2 gap-y-5 py-5 uppercase sm:py-10 lg:grid-cols-4 lg:gap-y-0"
      >
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-r border-neutral-300 text-center"
        >
          <p
            class="font-heading text-accent-red-dark text-2xl font-bold md:text-3xl lg:mb-5 lg:text-4xl xl:text-5xl"
          >
            <AnimatedCounter target={countries} />
          </p>
          <p class="font-heading text-xs font-medium md:text-base">countries</p>
        </div>
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-l border-neutral-300 text-center lg:border-x"
        >
          <p
            class="font-heading text-accent-red-dark text-2xl font-bold md:text-3xl lg:mb-5 lg:text-4xl xl:text-5xl"
          >
            <AnimatedCounter target={cities} />
          </p>
          <p class="font-heading text-xs font-medium md:text-base">cities</p>
        </div>
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-r border-neutral-300 text-center lg:border-x"
        >
          <p
            class="font-heading text-accent-red-dark text-2xl font-bold md:text-3xl lg:mb-5 lg:text-4xl xl:text-5xl"
          >
            <AnimatedCounter target={participants} />
          </p>
          <p class="font-heading text-xs font-medium md:text-base">
            participants
          </p>
        </div>
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-l border-neutral-300 text-center"
        >
          <p
            class="font-heading text-accent-red-dark text-2xl font-bold md:text-3xl lg:mb-5 lg:text-4xl xl:text-5xl"
          >
            <AnimatedCounter target={commitments} />
          </p>
          <p class="font-heading text-xs font-medium md:text-base">
            commitments
          </p>
        </div>
      </div>
      <ActionButton
        href="/arise26"
        bg="bg-accent-red-dark"
        hover="group-hover:text-accent-red-dark"
        iconHover="group-hover:text-accent-red-dark"
        >Learn more about our impact</ActionButton
      >
    </section>

    <!-- <section id="where-is-arise" class="flex flex-col pt-20">
      <h2 class="font-heading text-h4 uppercase">Where is Arise Now?</h2>
      <p class="text-p">
        Click to find out more about what is happening in a specific country
      </p>
    </section> -->

    <!-- <section>
      <h2>Latest Posts</h2>
      <ul>
        {posts.map((post) => <PostCard post={post} locale={locale!} />)}
      </ul>
    </section> -->
  </div>

  <section
    id="about-us"
    class="relative mt-20 flex min-h-screen flex-col items-center justify-center bg-[url('/about-us-bg.png')] bg-cover bg-center md:bg-top"
  >
    <div class="absolute inset-0 bg-linear-to-b from-transparent to-black">
    </div>
    <div
      class="relative z-10 container mx-auto flex flex-col px-8 text-center text-white md:px-16 lg:px-48"
    >
      <p
        class="mb-8 text-lg font-bold tracking-wider uppercase underline md:text-xl lg:text-2xl"
      >
        About Us
      </p>
      <h2
        class="font-heading mb-10 text-5xl font-semibold tracking-wider uppercase md:text-6xl lg:text-7xl"
      >
        What is <span class="text-primary-orange text-nowrap">Arise Asia</span>?
      </h2>
      <p class="mb-16 text-base md:text-lg lg:text-xl">
        Arise Asia is a missions movement launched in 2023 to inspire young
        adults across Asia and beyond to take the gospel where it has never been
        heard.
      </p>
      <div
        class="flex flex-col items-center gap-y-8 md:flex-row md:justify-center md:gap-x-5"
      >
        <ActionButton
          href="/about-us"
          bg="bg-black"
          textColor="text-black"
          innerBg="bg-white"
          innerHover="hover:bg-black"
          hover="group-hover:text-white"
          iconHover="group-hover:text-white">Learn About Us</ActionButton
        >
        <ActionButton
          href="/about-us"
          bg="bg-transparent"
          hover="group-hover:text-black"
          iconHover="group-hover:text-black">Our Partners</ActionButton
        >
      </div>
    </div>
  </section>

  <section
    id="take-action"
    class="container mx-auto mt-4 mb-5 grid grid-cols-1 gap-4 px-4 md:mt-8 md:mb-10 md:grid-cols-3 md:px-2"
  >
    <!-- Take Action — full width -->
    <div
      class="from-accent-purple-dark to-accent-purple-primary flex flex-row items-center gap-x-10 rounded-xl bg-linear-to-r p-3.5 md:col-span-3 md:p-7"
    >
      <div class="max-w-5xl space-y-5">
        <h2
          class="font-heading text-4xl font-semibold text-white uppercase md:text-5xl lg:text-6xl"
        >
          Take Action
        </h2>
        <p class="text-white">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Proin mattis
          aliquam leo id faucibus. Nullam vestibulum justo eu sem imperdiet
          fermentum. Sed vitae tristique ex. Lorem ipsum dolor sit amet,
          consectetur adipiscing elit. Proin mattis aliquam leo id faucibus.
          Nullam vestibulum justo eu sem imperdiet fermentum. Sed vitae
          tristique ex.
        </p>
      </div>
      <div class="relative flex size-60 shrink-0 items-center">
        <div
          class="bg-accent-purple-dark absolute bottom-4 left-8 size-48 shrink-0 -rotate-8"
          style="-webkit-mask: url('/icons/fire.svg') no-repeat center / contain; mask: url('/icons/fire.svg') no-repeat center / contain;"
        >
        </div>
        <div
          class="bg-accent-purple-dark absolute top-10 left-72 size-24 shrink-0 -rotate-15"
          style="-webkit-mask: url('/icons/cross.svg') no-repeat center / contain; mask: url('/icons/cross.svg') no-repeat center / contain;"
        >
        </div>
        <div
          class="bg-accent-purple-dark absolute bottom-8 left-64 size-12 shrink-0 -rotate-96"
          style="-webkit-mask: url('/icons/stone.svg') no-repeat center / contain; mask: url('/icons/stone.svg') no-repeat center / contain;"
        >
        </div>
        <div
          class="bg-accent-purple-dark absolute top-4 left-52 size-12 shrink-0 rotate-24"
          style="-webkit-mask: url('/icons/wave.svg') no-repeat center / contain; mask: url('/icons/wave.svg') no-repeat center / contain;"
        >
        </div>
        <div
          class="bg-accent-purple-dark absolute top-5 size-16 shrink-0 rotate-16"
          style="-webkit-mask: url('/icons/spark.svg') no-repeat center / contain; mask: url('/icons/spark.svg') no-repeat center / contain;"
        >
        </div>
      </div>
    </div>

    <!-- Give + Volunteer column (⅔ width) -->
    <div class="grid grid-rows-2 gap-4 md:col-span-2">
      <a
        href="/give"
        class="group relative flex items-center justify-between overflow-hidden rounded-xl bg-[url('/give-bg.png')] bg-cover bg-center px-3.5 py-7 transition-all duration-300 md:p-7"
      >
        <div
          class="absolute inset-0 bg-linear-to-t from-black via-black/40 to-transparent transition-opacity duration-300 group-hover:opacity-80 active:opacity-80"
        >
        </div>
        <div class="relative z-10 flex flex-col gap-y-2">
          <p
            class="text-accent-purple-light font-heading text-2xl uppercase md:text-3xl"
          >
            Give
          </p>
          <p
            class="text-neutral-cool-lightest text-sm tracking-wide md:text-base"
          >
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Proin
            mattis aliquam leo id faucibus.
          </p>
        </div>
        <div class="hidden md:flex-1"></div>
        <ArrowRight
          className="text-accent-purple-light relative z-10 size-10 transition-transform duration-300 group-hover:scale-110 active:scale-110"
        />
      </a>
      <a
        href="/volunteer"
        class="group relative flex items-center justify-between overflow-hidden rounded-xl bg-[url('/about-us-bg.png')] bg-cover bg-center px-3.5 py-7 transition-all duration-300 md:p-7"
      >
        <div
          class="absolute inset-0 bg-linear-to-t from-black via-black/40 to-transparent transition-opacity duration-300 group-hover:opacity-80 active:opacity-80"
        >
        </div>
        <div class="relative z-10 flex flex-col gap-y-2">
          <p
            class="text-accent-purple-light font-heading text-2xl uppercase md:text-3xl"
          >
            Volunteer
          </p>
          <p
            class="text-neutral-cool-lightest text-sm tracking-wide md:text-base"
          >
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Proin
            mattis aliquam leo id faucibus.
          </p>
        </div>
        <div class="hidden md:flex-1"></div>
        <ArrowRight
          className="text-accent-purple-light relative z-10 size-10 transition-transform duration-300 group-hover:scale-110 active:scale-110"
        />
      </a>
    </div>

    <!-- More ways to take action (⅓ width) -->
    <div class="flex flex-col gap-4 rounded-xl md:col-span-1">
      <p
        class="font-heading text-accent-purple-darker text-lg font-medium uppercase md:text-xl"
      >
        More ways to take action:
      </p>
      <SimpleButton
        size="sm"
        href="/1"
        className="text-accent-purple-dark border-accent-purple-dark hover:bg-accent-purple-dark border-2 bg-transparent font-medium hover:text-white"
        >Represent Arise Asia</SimpleButton
      >
      <SimpleButton
        size="sm"
        href="/1"
        className="text-accent-purple-dark border-accent-purple-dark hover:bg-accent-purple-dark border-2 bg-transparent font-medium hover:text-white"
        >Prayer Movement</SimpleButton
      >
      <SimpleButton
        size="sm"
        href="/1"
        className="text-accent-purple-dark border-accent-purple-dark hover:bg-accent-purple-dark border-2 bg-transparent font-medium hover:text-white"
        >Become a Mentor</SimpleButton
      >
      <SimpleButton
        size="sm"
        href="/1"
        className="text-accent-purple-dark border-accent-purple-dark hover:bg-accent-purple-dark border-2 bg-transparent font-medium hover:text-white"
        >Become a Sending Partner</SimpleButton
      >
      <SimpleButton
        size="sm"
        href="/1"
        className="text-accent-purple-dark border-accent-purple-dark hover:bg-accent-purple-dark border-2 bg-transparent font-medium hover:text-white"
        >Bring Arise Asia to Your Country</SimpleButton
      >
    </div>
  </section>
</Layout>

<script>
  const target = new Date("2026-07-27T00:00:00+08:00").getTime();

  function updateCountdown() {
    const diff = Math.max(0, Math.floor((target - Date.now()) / 1000));

    document.getElementById("countdown-days")!.textContent = String(
      Math.floor(diff / 86400),
    ).padStart(2, "0");
    document.getElementById("countdown-hours")!.textContent = String(
      Math.floor((diff % 86400) / 3600),
    ).padStart(2, "0");
    document.getElementById("countdown-minutes")!.textContent = String(
      Math.floor((diff % 3600) / 60),
    ).padStart(2, "0");
    document.getElementById("countdown-seconds")!.textContent = String(
      diff % 60,
    ).padStart(2, "0");

    if (diff <= 0) clearInterval(interval);
  }

  const interval = setInterval(updateCountdown, 1000);
  updateCountdown();
</script>
