---
import { Icon } from "astro-icon/components";
import PostCard from "@/components/shared/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE_NAME } from "@/lib/constants";
import { getPosts } from "@/lib/services/posts";
import AnimatedCounter from "@/components/shared/AnimatedCounter.astro";

const { locale } = Astro.params;
const posts = await getPosts(locale);
const countries = 12;
const cities = 40;
const participants = 12345;
const commitments = 7890;
---

<Layout title={SITE_NAME} locale={locale!}>
  <header>
    <div class="container mx-auto px-4 pt-40 sm:px-10 sm:pt-48">
      <div class="relative flex items-center justify-center gap-x-10">
        <div class="w-fit">
          <p
            class="font-heading w-fit bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text font-semibold tracking-wider text-transparent uppercase sm:text-3xl md:text-4xl"
          >
            Arise Asia 2026
          </p>
          <h1
            class="font-heading bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-6xl font-bold text-nowrap text-transparent uppercase sm:text-8xl md:text-9xl lg:text-8xl xl:text-9xl"
          >
            For The
          </h1>
          <div
            class="font-heading flex justify-between text-xs font-bold uppercase sm:text-base md:text-xl"
          >
            <p
              class="bg-linear-to-r from-[#2563eb] to-[#3172f0] bg-clip-text text-transparent"
            >
              27-31 July
            </p>
            <p
              class="bg-linear-to-r from-[#3172f0] to-[#3b82f6] bg-clip-text text-transparent"
            >
              Manila, Philippines
            </p>
          </div>
        </div>
        <div class="relative">
          <img
            alt="Joy"
            class="-mt-4 w-40 sm:w-60 md:w-80 lg:mt-10 xl:w-96"
            src="/joy.svg"
          />
        </div>
      </div>
      <div class="mx-auto mb-10 flex flex-col items-center">
        <p
          class="font-heading text-h4 mt-2 font-medium text-neutral-600 uppercase"
        >
          is happening in...
        </p>
        <div class="mt-6 flex items-center gap-x-2 sm:gap-x-6 md:gap-x-10">
          <div class="flex flex-col items-center">
            <p id="countdown-days" class="text-h2 text-blue-900">00</p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Days
            </p>
          </div>
          <p class="text-h3 text-neutral-500">:</p>
          <div class="flex flex-col items-center">
            <p id="countdown-hours" class="text-h2 text-blue-900">00</p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Hours
            </p>
          </div>
          <p class="text-h3 text-neutral-500">:</p>
          <div class="flex flex-col items-center">
            <p id="countdown-minutes" class="text-h2 text-blue-900">00</p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Minutes
            </p>
          </div>
          <p class="text-h3 text-neutral-500">:</p>
          <div class="flex flex-col items-center">
            <p id="countdown-seconds" class="text-h2 text-blue-900">00</p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Seconds
            </p>
          </div>
        </div>
        <a
          href="/arise26"
          class="mx-auto mt-8 w-fit rounded-full bg-[linear-gradient(100deg,#2781FF_-8.62%,#6BA7FF_48.41%,#FFA456_76.92%,#FE4C5A_105.43%)] p-0.5"
        >
          <div
            class="group rounded-full px-8 py-4 text-white uppercase hover:bg-white"
          >
            <p
              class="font-heading flex items-center gap-x-2 text-xs font-semibold group-hover:bg-[linear-gradient(100deg,#2781FF_-8.62%,#6BA7FF_48.41%,#FFA456_76.92%,#FE4C5A_105.43%)] group-hover:bg-clip-text group-hover:text-transparent sm:text-base"
            >
              Learn more now
              <Icon
                name="lucide:arrow-right"
                class="size-5 group-hover:text-[#FE4C5A]"
              />
            </p>
          </div>
        </a>
      </div>
    </div>
  </header>

  <div class="bg-zinc-50 sm:px-10 md:px-20 lg:px-48">
    <section id="vision" class="flex flex-col items-center pt-10">
      <div class="flex items-end pb-5">
        <img
          alt="Arise logo - black font"
          class="size-28"
          src="/logo-black-font.svg"
        />
        <p
          class="font-heading -mb-1.5 -ml-4 text-5xl font-medium whitespace-nowrap uppercase"
        >
          rise Asia
        </p>
      </div>
      <p class="font-heading pb-2 text-center text-3xl">
        By 2033, our goal is that 100,000 young people from 500 cities and 50
        countries in Asia and beyond will receive the challenge to
      </p>
      <p
        class="font-heading bg-[linear-gradient(90deg,#FE5F5B_0%,#FFA45B_100%)] bg-clip-text text-6xl font-semibold text-transparent uppercase"
      >
        Go where there is no Gospel
      </p>
    </section>

    <section id="impact" class="flex flex-col items-center pt-20">
      <p class="text-h3 font-heading font-normal uppercase">
        Our Impact To-Date
      </p>
      <div class="grid w-full grid-cols-4 py-4 uppercase sm:py-8">
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-r border-neutral-300 text-center"
        >
          <p
            class="font-heading text-accent-red-dark text-lg font-medium md:text-3xl lg:text-5xl"
          >
            <AnimatedCounter target={countries} />
          </p>
          <p
            class="font-heading text-[0.5rem] font-medium sm:text-xs md:text-base"
          >
            countries
          </p>
        </div>
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-x border-neutral-300 text-center"
        >
          <p
            class="font-heading text-accent-red-dark text-lg font-medium md:text-3xl lg:text-5xl"
          >
            <AnimatedCounter target={cities} />
          </p>
          <p
            class="font-heading text-[0.5rem] font-medium sm:text-xs md:text-base"
          >
            cities
          </p>
        </div>
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-x border-neutral-300 text-center"
        >
          <p
            class="font-heading text-accent-red-dark text-lg font-medium md:text-3xl lg:text-5xl"
          >
            <AnimatedCounter target={participants} />
          </p>
          <p
            class="font-heading text-[0.5rem] font-medium sm:text-xs md:text-base"
          >
            participants
          </p>
        </div>
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-l border-neutral-300 text-center"
        >
          <p
            class="font-heading text-accent-red-dark text-lg font-medium md:text-3xl lg:text-5xl"
          >
            <AnimatedCounter target={commitments} />
          </p>
          <p
            class="font-heading text-[0.5rem] font-medium sm:text-xs md:text-base"
          >
            commitments
          </p>
        </div>
      </div>
      <a
        href="/arise26"
        class="bg-accent-red-dark mx-auto w-fit rounded-full p-0.5"
      >
        <div
          class="group rounded-full px-8 py-4 text-white uppercase hover:bg-white"
        >
          <p
            class="font-heading group-hover:bg-accent-red-dark flex items-center gap-x-2 text-xs font-semibold group-hover:bg-clip-text group-hover:text-transparent sm:text-base"
          >
            Learn more about our impact
            <Icon
              name="lucide:arrow-right"
              class="group-hover:text-accent-red-dark size-5"
            />
          </p>
        </div>
      </a>
    </section>

    <section id="where-is-arise" class="flex flex-col items-center pt-20">
    </section>

    <section id="upcoming-events" class="flex flex-col items-center pt-20">
    </section>

    <!-- <section>
      <h2>Latest Posts</h2>
      <ul>
        {posts.map((post) => <PostCard post={post} locale={locale!} />)}
      </ul>
    </section> -->
  </div>

  <section id="impact-stories" class="flex flex-col items-center pt-20">
  </section>
</Layout>

<script>
  const target = new Date("2026-07-27T00:00:00+08:00").getTime();

  function updateCountdown() {
    const diff = Math.max(0, Math.floor((target - Date.now()) / 1000));

    document.getElementById("countdown-days")!.textContent = String(
      Math.floor(diff / 86400),
    ).padStart(2, "0");
    document.getElementById("countdown-hours")!.textContent = String(
      Math.floor((diff % 86400) / 3600),
    ).padStart(2, "0");
    document.getElementById("countdown-minutes")!.textContent = String(
      Math.floor((diff % 3600) / 60),
    ).padStart(2, "0");
    document.getElementById("countdown-seconds")!.textContent = String(
      diff % 60,
    ).padStart(2, "0");

    if (diff <= 0) clearInterval(interval);
  }

  const interval = setInterval(updateCountdown, 1000);
  updateCountdown();
</script>
