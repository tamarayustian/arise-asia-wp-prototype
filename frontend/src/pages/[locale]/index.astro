---
import PostCard from "@/components/shared/PostCard.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE_NAME } from "@/lib/constants";
import { getPosts } from "@/lib/services/posts";
import { ActionButton } from "@/components/shared/ActionButton";
import AnimatedCounter from "@/components/shared/AnimatedCounter.astro";

const { locale } = Astro.params;
const posts = await getPosts(locale);
const countries = 12;
const cities = 40;
const participants = 12345;
const commitments = 7890;
---

<Layout title={SITE_NAME} locale={locale!}>
  <header>
    <div class="container mx-auto px-8 pt-40 sm:pt-48">
      <!-- Mobile layout (below md) -->
      <div class="flex flex-col md:hidden">
        <p
          class="font-heading w-fit bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-2xl font-semibold tracking-wider text-nowrap text-transparent uppercase"
        >
          Arise Asia 2026
        </p>
        <div class="flex items-start justify-center">
          <h1
            class="font-heading bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-6xl sm:text-7xl font-bold text-transparent uppercase"
          >
            <span class="block">For</span>
            <span class="block">The</span>
          </h1>
          <img
            alt="Joy"
            class="w-56 shrink-0"
            src="/joy.svg"
          />
        </div>
        <div
          class="font-heading flex justify-between text-xs font-bold uppercase sm:text-base"
        >
          <p
            class="bg-linear-to-r from-[#2563eb] to-[#3172f0] bg-clip-text text-nowrap text-transparent"
          >
            27-31 July
          </p>
          <p
            class="bg-linear-to-r from-[#3172f0] to-[#3b82f6] bg-clip-text text-nowrap text-transparent"
          >
            Manila, Philippines
          </p>
        </div>
      </div>
      <!-- Desktop layout (md+) -->
      <div class="hidden md:flex md:items-center md:justify-center md:gap-x-6 lg:items-center lg:justify-center">
        <div class="w-fit">
          <p
            class="font-heading w-fit bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-2xl font-semibold tracking-wider text-nowrap text-transparent uppercase md:text-3xl lg:text-4xl"
          >
            Arise Asia 2026
          </p>
          <h1
            class="font-heading bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-6xl font-bold text-transparent uppercase sm:text-6xl md:text-7xl md:text-nowrap lg:text-8xl xl:text-9xl"
          >
            For The
          </h1>
          <div
            class="font-heading flex justify-between font-bold uppercase text-base lg:text-xl"
          >
            <p
              class="bg-linear-to-r from-[#2563eb] to-[#3172f0] bg-clip-text text-nowrap text-transparent"
            >
              27-31 July
            </p>
            <p
              class="bg-linear-to-r from-[#3172f0] to-[#3b82f6] bg-clip-text text-nowrap text-transparent"
            >
              Manila, Philippines
            </p>
          </div>
        </div>
        <div class="relative">
          <img
            alt="Joy"
            class="md:mt-10 md:w-80 lg:mt-10 xl:w-96"
            src="/joy.svg"
          />
        </div>
      </div>
      <div class="mx-auto mt-5 mb-10 xl:mb-12 flex flex-col items-center">
        <p
          class="font-heading text-h4 mt-2 font-medium text-[#2b2b2b] uppercase"
        >
          is happening in...
        </p>
        <div class="sm:mt-6 flex items-center gap-x-2 sm:gap-x-6 md:gap-x-10">
          <div class="flex flex-col items-center">
            <p id="countdown-days" class="text-h2 lg:text-h1 text-blue-900">00</p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Days
            </p>
          </div>
          <p class="text-h3 text-neutral-500">:</p>
          <div class="flex flex-col items-center">
            <p id="countdown-hours" class="text-h2 lg:text-h1 text-blue-900">00</p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Hours
            </p>
          </div>
          <p class="text-h3 text-neutral-500">:</p>
          <div class="flex flex-col items-center">
            <p id="countdown-minutes" class="text-h2 lg:text-h1 text-blue-900">00</p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Minutes
            </p>
          </div>
          <p class="text-h3 text-neutral-500">:</p>
          <div class="flex flex-col items-center">
            <p id="countdown-seconds" class="text-h2 lg:text-h1 text-blue-900">00</p>
            <p
              class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
            >
              Seconds
            </p>
          </div>
        </div>
        <ActionButton className="mt-10" href="/arise26">Learn more now</ActionButton>
      </div>
    </div>
  </header>

  <div class="bg-linear-to-b from-accent-orange-lightest to-white px-8 md:px-16 lg:px-48">
    <section id="vision" class="flex flex-col items-center pt-10">
      <div class="flex items-end pb-5">
        <img
          alt="Arise logo - black font"
          class="size-16 sm:size-24 md:size-28"
          src="/logo-black-font.svg"
        />
        <p
          class="font-heading -mb-1.5 -ml-2.5 sm:-ml-4 text-2xl sm:text-4xl md:text-5xl font-medium whitespace-nowrap uppercase"
        >
          rise Asia
        </p>
      </div>
      <p class="font-heading pb-2 text-center text-xl md:text-3xl">
        By 2033, our goal is that 100,000 young people from 500 cities and 50
        countries in Asia and beyond will receive the challenge to
      </p>
      <p
        class="font-heading bg-[linear-gradient(90deg,#FE5F5B_0%,#FFA45B_100%)] bg-clip-text text-center text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold text-transparent uppercase"
      >
        Go where there is no Gospel
      </p>
    </section>

    <section id="impact" class="flex flex-col items-center pt-20">
      <h2 class="text-h3 font-heading font-normal uppercase">
        Our Impact To-Date
      </h2>
      <div class="grid w-full grid-cols-4 py-4 uppercase sm:py-8">
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-r border-neutral-300 text-center"
        >
          <p
            class="font-heading text-accent-red-dark text-lg font-medium md:text-3xl lg:mb-5 lg:text-5xl"
          >
            <AnimatedCounter target={countries} />
          </p>
          <p
            class="font-heading text-[0.5rem] font-medium sm:text-xs md:text-base"
          >
            countries
          </p>
        </div>
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-x border-neutral-300 text-center"
        >
          <p
            class="font-heading text-accent-red-dark text-lg font-medium md:text-3xl lg:mb-5 lg:text-5xl"
          >
            <AnimatedCounter target={cities} />
          </p>
          <p
            class="font-heading text-[0.5rem] font-medium sm:text-xs md:text-base"
          >
            cities
          </p>
        </div>
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-x border-neutral-300 text-center"
        >
          <p
            class="font-heading text-accent-red-dark text-lg font-medium md:text-3xl lg:mb-5 lg:text-5xl"
          >
            <AnimatedCounter target={participants} />
          </p>
          <p
            class="font-heading text-[0.5rem] font-medium sm:text-xs md:text-base"
          >
            participants
          </p>
        </div>
        <div
          class="relative flex flex-1 flex-col items-center justify-center border-l border-neutral-300 text-center"
        >
          <p
            class="font-heading text-accent-red-dark text-lg font-medium md:text-3xl lg:mb-5 lg:text-5xl"
          >
            <AnimatedCounter target={commitments} />
          </p>
          <p
            class="font-heading text-[0.5rem] font-medium sm:text-xs md:text-base"
          >
            commitments
          </p>
        </div>
      </div>
      <ActionButton
        href="/arise26"
        bg="bg-accent-red-dark"
        hover="group-hover:text-accent-red-dark"
        iconHover="group-hover:text-accent-red-dark"
        >Learn more about our impact</ActionButton
      >
    </section>

    <section id="where-is-arise" class="flex flex-col pt-20">
      <h2 class="font-heading text-h4 uppercase">Where is Arise Now?</h2>
      <p class="text-p">
        Click to find out more about what is happening in a specific country
      </p>
    </section>

    <section id="upcoming-events" class="flex flex-col items-center pt-20">
    </section>

    <!-- <section>
      <h2>Latest Posts</h2>
      <ul>
        {posts.map((post) => <PostCard post={post} locale={locale!} />)}
      </ul>
    </section> -->
  </div>

  <section id="impact-stories" class="flex flex-col items-center pt-20">
  </section>
</Layout>

<script>
  const target = new Date("2026-07-27T00:00:00+08:00").getTime();

  function updateCountdown() {
    const diff = Math.max(0, Math.floor((target - Date.now()) / 1000));

    document.getElementById("countdown-days")!.textContent = String(
      Math.floor(diff / 86400),
    ).padStart(2, "0");
    document.getElementById("countdown-hours")!.textContent = String(
      Math.floor((diff % 86400) / 3600),
    ).padStart(2, "0");
    document.getElementById("countdown-minutes")!.textContent = String(
      Math.floor((diff % 3600) / 60),
    ).padStart(2, "0");
    document.getElementById("countdown-seconds")!.textContent = String(
      diff % 60,
    ).padStart(2, "0");

    if (diff <= 0) clearInterval(interval);
  }

  const interval = setInterval(updateCountdown, 1000);
  updateCountdown();
</script>
