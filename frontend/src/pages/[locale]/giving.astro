const givingOptionsData = [
  {
    id: "1",
    question: "How do I make a donation?",
    answer:
      "You can donate online via credit card, PayPal, or bank transfer. Choose the option that works best for you from the methods above.",
  },
  {
    id: "2",
    question: "Can I donate anonymously?",
    answer:
      "Yes, you can choose to remain anonymous. Your donation will still be processed, but your name will not appear in any public materials.",
  },
  {
    id: "3",
    question: "Is my donation tax-deductible?",
    answer:
      "Donations are tax-deductible in the countries where we are registered as a nonprofit. A receipt will be emailed to you after your donation.",
  },
  {
    id: "4",
