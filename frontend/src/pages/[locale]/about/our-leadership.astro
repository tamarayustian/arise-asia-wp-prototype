---
import AboutHero from "@/components/about/AboutHero.astro";
import LeaderCard from "@/components/about/LeaderCard.astro";
import Layout from "@/layouts/Layout.astro";
import { UserRound } from "lucide-react";

const { locale } = Astro.params;

const steeringCommittee = [
  { name: "David Ro", country: "Thailand", role: "Executive Director" },
  { name: "Patrick Fung", country: "Singapore", role: "Chairman of the Board" },
  {
    name: "Philip Chang",
    country: "Malaysia",
    role: "Head of Selection Committee",
  },
  { name: "JackiE Ro", country: "Thailand", role: "Arise Follow-Up Lead" },
  { name: "Joanna", country: "Hong Kong", role: "Director of Events" },
  { name: "AH", role: "Director of Church Engagement" },
  { name: "Prabhu Singh", country: "India", role: "Arise India Chair" },
  {
    name: "Priscilla Mageropoulos",
    country: "Thailand",
    role: "Marketing and Communications Manager",
  },
  {
    name: "Yoseph Tandian",
    country: "Indonesia",
    role: "Arise Follow-Up Strategist & Development Director",
  },
  {
    name: "Mitchelle Rajapakse",
    country: "Sri Lanka",
    role: "Arise Follow-Up Engagement Director",
  },
  {
    name: "CarmeN Tam",
    country: "Thailand",
    role: "Arise Internship Lead and Mentorship Coordinator",
  },
  ...Array.from({ length: 5 }, () => ({
    name: "Lalano Badoy",
    country: "Philippines",
    role: "Prayer Movement Coordinator and Arise Philippines Chair",
  })),
];

const categories = [
  {
    name: "Arise Global Board of Directors",
    leaders: [
      { name: "David Ro", role: "Executive Director" },
      { name: "Patrick Fung", role: "Chairman" },
      { name: "Philip Chang", role: "Chief Financial Officer" },
      { name: "Dick Yue", role: "Board Secretary" },
      { name: "Paul Borthwick", role: "Board Member" },
      { name: "Lawrence Tong", role: "Board Member" },
    ],
  },
  {
    name: "Arise Asia 2026 Steering Committee and Staff",
    leaders: steeringCommittee,
  },
  {
    name: "Arise National Leaders",
    leaders: steeringCommittee,
  },
  {
    name: "Arise Philippines | Arise Asia Board",
    leaders: [
      {
        name: "CarmeN Tam",
        country: "Thailand",
        role: "Arise Internship Lead and Mentorship Coordinator",
      },
      ...Array.from({ length: 5 }, () => ({
        name: "Lalano Badoy",
        country: "Philippines",
        role: "Prayer Movement Coordinator and Arise Philippines Chair",
      })),
    ],
  },
];
---

<Layout title="Our Leadership — Arise Asia" locale={locale!}>
  <section id="hero">
    <AboutHero breadcrumb="ABOUT US/" title="Leadership">
      <div class="flex flex-col items-center gap-8 md:flex-row md:items-center">
        <div
          class="border-accent-blue-lighter bg-accent-blue-lightest/60 flex aspect-square w-full max-w-56 shrink-0 items-center justify-center overflow-hidden rounded-full border-2"
        >
          <UserRound
            className="text-accent-blue-dark size-1/2"
            strokeWidth={1.5}
          />
        </div>
        <div class="flex flex-col gap-2">
          <p class="font-heading text-xl font-bold uppercase md:text-2xl">
            David Ro
          </p>
          <p
            class="font-heading text-accent-blue-dark text-xs font-semibold uppercase md:text-sm"
          >
            Executive Director
          </p>
          <p class="font-heading mt-2 text-base md:text-lg">
            My challenge to this generation: You have one life. The one
            challenge, find a people "where Christ is not known" and boldly go
            to "where there is no gospel" and lay down your life for another
            people in the footsteps of our Lord Jesus Christ.
          </p>
        </div>
      </div>
    </AboutHero>
  </section>

  <section
    id="leaders"
    class="container-page flex flex-col gap-16 px-8 py-10 md:px-16 lg:px-32 xl:px-48"
  >
    {
      categories.map((category) => (
        <div class="flex flex-col gap-6">
          <h2 class="font-heading from-accent-blue-dark to-primary-blue-lighter bg-linear-to-r bg-clip-text text-2xl font-semibold text-transparent uppercase md:text-4xl">
            {category.name}
          </h2>
          <div class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 lg:grid-cols-4">
            {category.leaders.map((leader) => (
              <LeaderCard
                name={leader.name}
                role={leader.role}
                country={leader.country}
              />
            ))}
          </div>
        </div>
      ))
    }
  </section>
</Layout>
