---
import AboutHero from "@/components/about/AboutHero.astro";
import PartnerLogoGrid from "@/components/about/PartnerLogoGrid.astro";
import Layout from "@/layouts/Layout.astro";

const { locale } = Astro.params;

const endorsingPartners = [
  "Cru",
  "Frontiers",
  "Gather",
  "Global",
  "HKACM",
  "ICMDA",
  "Every Nation",
  "Asia Evangelical",
  "Asia Theological",
  "China Evangelical",
];

const sponsoringPartners = ["123Go", "A3"];
---

<Layout title="Our Partners — Arise Asia" locale={locale!}>
  <section id="hero">
    <AboutHero breadcrumb="ABOUT US/ LEARN MORE" title="Our Partners" />
  </section>

  <section
    id="partners"
    class="container mx-auto flex flex-col gap-14 px-8 py-10 md:px-16 lg:px-32 xl:px-48"
  >
    <div class="flex flex-col gap-6">
      <h2
        class="font-heading from-accent-blue-dark to-primary-blue-lighter bg-linear-to-r bg-clip-text text-3xl font-semibold text-transparent uppercase md:text-4xl"
      >
        Endorsing Partners
      </h2>
      <PartnerLogoGrid partners={endorsingPartners} />
    </div>

    <div class="flex flex-col gap-6">
      <h2
        class="font-heading from-accent-orange-dark to-primary-orange bg-linear-to-r bg-clip-text text-3xl font-semibold text-transparent uppercase md:text-4xl"
      >
        Sponsoring Partners
      </h2>
      <PartnerLogoGrid partners={sponsoringPartners} />
    </div>
  </section>
</Layout>
