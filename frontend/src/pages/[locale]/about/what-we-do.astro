---
import AboutHero from "@/components/about/AboutHero.astro";
import Layout from "@/layouts/Layout.astro";
import { Flame } from "lucide-react";

const { locale } = Astro.params;

const strategicGatherings = [
  {
    title: "Arise Asia Global Event",
    sublabel: "(Every 3 Years)",
  },
  {
    title: "Arise National Gatherings",
    sublabel: "(Organized by Leadership Summit)",
  },
  {
    title: "Arise Executive Summit",
    sublabel: "(Leadership Alignment)",
  },
];

const missionsPathways = [
  {
    title: "1-Year Internship Pathways",
    sublabel: "(Arise Asia and partnering organizations)",
  },
  {
    title: "Short term cross cultural missions",
    sublabel: "(Both overseas and in-country)",
  },
  {
    title: "Long-term missions",
    sublabel: "(With various missions agencies)",
  },
];
---

<Layout title="What We Do — Arise Asia" locale={locale!}>
  <AboutHero breadcrumb="ABOUT US/" title="What We Do">
    <p class="font-heading max-w-3xl text-base md:text-lg">
      Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod
      tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim
      veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea
      commodo consequat.
    </p>
  </AboutHero>

  <section
    id="pathways"
    class="container-page flex flex-col gap-4 px-8 py-10 md:px-16 lg:px-32 xl:px-48"
  >
    <div
      class="bg-accent-blue-dark flex items-center justify-center rounded-2xl p-5 md:p-6"
    >
      <p class="font-heading text-center text-lg font-semibold text-white uppercase md:text-2xl">
        3 Strategic Gatherings
      </p>
    </div>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      {
        strategicGatherings.map((item) => (
          <div class="bg-accent-blue-lightest flex flex-col items-center gap-1 rounded-2xl p-6 text-center">
            <Flame className="text-accent-blue-light mb-1 size-10" />
            <p class="font-heading text-accent-blue-light text-lg font-medium uppercase">
              {item.title}
            </p>
            <p class="font-heading text-sm">{item.sublabel}</p>
          </div>
        ))
      }
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div class="flex flex-col gap-4">
        <div
          class="bg-accent-purple-primary flex items-center justify-center rounded-2xl p-5 md:p-6"
        >
          <p class="font-heading text-center text-lg font-semibold text-white uppercase md:text-2xl">
            PrayerFUL Commitments
          </p>
        </div>
        <div class="bg-accent-purple-lightest flex flex-col items-center gap-1 rounded-2xl p-6 text-center">
          <Flame className="text-accent-purple-dark mb-1 size-10" />
          <p class="font-heading text-accent-purple-dark text-lg font-medium uppercase">
            123Go
          </p>
          <p class="font-heading text-sm">(A young person's commitment)</p>
        </div>
      </div>
      <div class="flex flex-col gap-4">
        <div
          class="bg-accent-red-dark flex items-center justify-center rounded-2xl p-5 md:p-6"
        >
          <p class="font-heading text-center text-lg font-semibold text-white uppercase md:text-2xl">
            Dedicated SUPPORT
          </p>
        </div>
        <div class="bg-accent-red-lightest flex flex-col items-center gap-1 rounded-2xl p-6 text-center">
          <Flame className="text-accent-red-dark mb-1 size-10" />
          <p class="font-heading text-accent-red-dark text-lg font-medium uppercase">
            Mentoring and Follow-up
          </p>
        </div>
      </div>
    </div>

    <div
      class="bg-primary-orange flex items-center justify-center rounded-2xl p-5 md:p-6"
    >
      <p class="font-heading text-center text-lg font-semibold text-white uppercase md:text-2xl">
        Missions Pathways
      </p>
    </div>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      {
        missionsPathways.map((item) => (
          <div class="bg-accent-orange-lightest flex flex-col items-center gap-1 rounded-2xl p-6 text-center">
            <Flame className="text-accent-orange-dark mb-1 size-10" />
            <p class="font-heading text-accent-orange-dark text-lg font-medium uppercase">
              {item.title}
            </p>
            <p class="font-heading text-sm">{item.sublabel}</p>
          </div>
        ))
      }
    </div>
  </section>
</Layout>
