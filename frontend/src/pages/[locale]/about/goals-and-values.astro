---
import AboutHero from "@/components/about/AboutHero.astro";
import OurGoalSection from "@/components/about/OurGoalSection.astro";
import Layout from "@/layouts/Layout.astro";

const { locale } = Astro.params;

const values = [
  {
    letter: "A",
    title: "Acquiring the Heart of God",
    description: "We ask God to break our hearts for what breaks His, awakening compassion for the people and places across Asia that have yet to encounter His love.",
    color: "border-accent-blue-light text-accent-blue-dark",
  },
  {
    letter: "R",
    title: "Relinquish our Rights",
    description: "We surrender our own plans and comforts, trusting God's purposes above our own as we follow Him faithfully today.",
    color: "border-primary-orange text-primary-orange",
  },
  {
    letter: "I",
    title: "Intimacy with God",
    description: "We pursue a deep, personal relationship with God through prayer and worship, staying rooted in Him above all else.",
    color: "border-accent-red-light text-primary-red",
  },
  {
    letter: "S",
    title: "Sacrificial Living",
    description: "We choose to live simply and give generously, laying down comfort so others may experience the love of Christ today.",
    color: "border-accent-purple-light text-accent-purple-primary",
  },
  {
    letter: "E",
    title: "Empowering to Boldly Go",
    description: "We equip and release young leaders with courage, sending them to serve in places where they are needed most.",
    color: "border-primary-blue text-primary-blue",
  },
];
---

<Layout title="Our Goal & Values — Arise Asia" locale={locale!}>
  <AboutHero breadcrumb="ABOUT US/" title="Our Goal & Values" />

  <section
    id="our-goal"
    class="container-page flex flex-col gap-6 px-8 py-10 md:px-16 lg:px-32 xl:px-48"
  >
    <h2
      class="font-heading from-accent-orange-dark to-primary-orange bg-linear-to-r bg-clip-text text-3xl font-semibold text-transparent uppercase md:text-4xl"
    >
      Our Goal
    </h2>
    <OurGoalSection variant="card" showHeading={false} />
    <p class="font-heading text-base md:text-lg">
      This goal drives every gathering, every follow-up conversation, and every mentoring relationship we build together, as we equip young leaders across Asia to respond faithfully and serve wherever they are called today.
    </p>
  </section>

  <section
    id="values"
    class="container-page flex flex-col gap-6 px-8 py-10 md:px-16 lg:px-32 xl:px-48"
  >
    <h2
      class="font-heading from-accent-orange-dark to-primary-orange bg-linear-to-r bg-clip-text text-3xl font-semibold text-transparent uppercase md:text-4xl"
    >
      The Values
    </h2>
    <p class="font-heading text-base md:text-lg">
      Our values guide how we live, serve, and lead as a movement, shaping the way we walk with young leaders across Asia as they respond to the call to serve wherever God places them today.
    </p>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {
        values.map((value) => (
          <div
            class={`flex flex-col items-center justify-between gap-3 rounded-xl border-2 p-5 text-center ${value.color}`}
          >
            <p class="font-heading text-5xl font-medium uppercase">
              {value.letter}
            </p>
            <p class="font-heading text-lg font-medium">{value.title}</p>
            <p class="font-heading text-sm text-black">
              {value.description}
            </p>
          </div>
        ))
      }
    </div>
    <div class="grid grid-cols-6 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {
        Array.from({ length: 5 }).map((_, i) => (
          <div
            class={`aspect-square overflow-hidden rounded-xl sm:col-span-1 ${i < 3 ? "col-span-2" : "col-span-3"}`}
          >
            <img
              alt="Arise Asia community"
              class="size-full object-cover"
              src="/images/about-us-bg.png"
            />
          </div>
        ))
      }
    </div>
  </section>
</Layout>
