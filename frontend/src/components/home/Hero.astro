---
import { ActionButton } from "@/components/shared/ActionButton";

const { videoUrl } = Astro.props;
---

<div class="relative z-10 container mx-auto px-8 pt-56 sm:pt-64">
  <!-- Mobile layout (below md) -->
  <div class="flex flex-col md:hidden">
    <p
      class="font-heading w-fit bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-2xl font-semibold tracking-wider text-nowrap text-transparent uppercase"
    >
      Arise Asia 2026
    </p>
    <div class="flex items-start justify-center">
      <h1
        class="font-heading bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-5xl font-bold text-transparent uppercase sm:text-6xl"
      >
        <span class="block">For</span>
        <span class="block">The</span>
      </h1>
      <img alt="Joy" class="w-48 shrink-0" src="/joy.svg" />
    </div>
    <div
      class="font-heading flex justify-between text-xs font-bold uppercase sm:text-base"
    >
      <p
        class="bg-linear-to-r from-[#2563eb] to-[#3172f0] bg-clip-text text-nowrap text-transparent"
      >
        27-31 July
      </p>
      <p
        class="bg-linear-to-r from-[#3172f0] to-[#3b82f6] bg-clip-text text-nowrap text-transparent"
      >
        Manila, Philippines
      </p>
    </div>
  </div>
  <!-- Desktop layout (md+) -->
  <div
    class="hidden md:flex md:items-center md:justify-center md:gap-x-6 lg:items-center lg:justify-center"
  >
    <div class="w-fit">
      <p
        class="font-heading w-fit bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-2xl font-semibold tracking-wider text-nowrap text-transparent uppercase md:text-3xl lg:text-4xl"
      >
        Arise Asia 2026
      </p>
      <h1
        class="font-heading bg-linear-to-r from-blue-600 to-blue-500 bg-clip-text text-6xl font-bold text-transparent uppercase sm:text-6xl md:text-7xl md:text-nowrap lg:text-8xl xl:text-9xl md:my-2 lg:my-0"
      >
        For The
      </h1>
      <div
        class="font-heading flex justify-between text-base font-bold uppercase lg:text-xl"
      >
        <p
          class="bg-linear-to-r from-[#2563eb] to-[#3172f0] bg-clip-text text-nowrap text-transparent"
        >
          27-31 July
        </p>
        <p
          class="bg-linear-to-r from-[#3172f0] to-[#3b82f6] bg-clip-text text-nowrap text-transparent"
        >
          Manila, Philippines
        </p>
      </div>
    </div>
    <div class="relative">
      <img alt="Joy" class="md:mt-10 md:w-80 lg:mt-10 xl:w-96" src="/joy.svg" />
    </div>
  </div>
  <div class="mx-auto mt-5 mb-10 flex flex-col items-center xl:mb-12">
    <p class="font-heading text-h4 mt-2 font-medium text-[#2b2b2b] uppercase">
      is happening in...
    </p>
    <div class="flex items-center gap-x-2 sm:mt-6 sm:gap-x-6 md:gap-x-10">
      <div class="flex flex-col items-center w-18 md:w-20 lg:w-28 xl:w-32">
        <p id="countdown-days" class="text-h2 lg:text-h1 text-blue-900">00</p>
        <p
          class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
        >
          Days
        </p>
      </div>
      <p class="text-h3 text-neutral-500">:</p>
      <div class="flex flex-col items-center w-18 md:w-20 lg:w-28 xl:w-32">
        <p id="countdown-hours" class="text-h2 lg:text-h1 text-blue-900">00</p>
        <p
          class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
        >
          Hours
        </p>
      </div>
      <p class="text-h3 text-neutral-500">:</p>
      <div class="flex flex-col items-center w-18 md:w-20 lg:w-28 xl:w-32">
        <p id="countdown-minutes" class="text-h2 lg:text-h1 text-blue-900">
          00
        </p>
        <p
          class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
        >
          Minutes
        </p>
      </div>
      <p class="text-h3 text-neutral-500">:</p>
      <div class="flex flex-col items-center w-18 md:w-20 lg:w-28 xl:w-32">
        <p id="countdown-seconds" class="text-h2 lg:text-h1 text-blue-900">
          00
        </p>
        <p
          class="font-heading text-xs font-medium text-neutral-800 uppercase sm:text-base"
        >
          Seconds
        </p>
      </div>
    </div>
    <ActionButton className="mt-10" href="/arise26">Learn more now</ActionButton
    >
    <div class="mx-auto mt-10 w-full max-w-md md:max-w-lg lg:max-w-2xl">
      <div class="aspect-video overflow-hidden rounded-2xl">
        <iframe
          class="h-full w-full"
          src={videoUrl}
          title="YouTube video"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        >
        </iframe>
      </div>
    </div>
  </div>
</div>
