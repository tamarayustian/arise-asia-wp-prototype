---
import { UserRound } from "lucide-react";

export interface Props {
  name: string;
  role: string;
  country?: string;
}

const { name, role, country } = Astro.props;
---

<div class="flex flex-col items-center gap-3 text-center">
  <div
    class="border-accent-blue-lighter bg-accent-blue-lightest/60 flex aspect-square w-full max-w-40 items-center justify-center overflow-hidden rounded-full border-2"
  >
    <UserRound className="text-accent-blue-dark size-1/2" strokeWidth={1.5} />
  </div>
  <div class="flex flex-col items-center gap-1">
    <p class="font-heading text-sm font-bold uppercase md:text-base">
      {name}
    </p>
    <p class="text-neutral-gray-light text-xs md:text-sm">{role}</p>
    {
      country && (
        <span class="bg-accent-blue-lightest text-accent-blue-dark font-heading rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase md:text-xs">
          {country}
        </span>
      )
    }
  </div>
</div>
