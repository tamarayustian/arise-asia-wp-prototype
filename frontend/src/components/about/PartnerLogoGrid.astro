---
export interface Props {
  partners: string[];
}

const { partners } = Astro.props;
---

<div
  class="grid grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5"
>
  {
    partners.map((partner) => (
      <div class="border-neutral-cool-lighter flex aspect-square items-center justify-center rounded-xl border bg-white p-4 md:p-6">
        <p class="font-heading text-neutral-gray-lighter text-center text-sm font-medium uppercase md:text-base">
          {partner}
        </p>
      </div>
    ))
  }
</div>
