---
import { LOCALES } from '@/lib/constants';

export interface Props {
  currentLocale: string;
}

const { currentLocale } = Astro.props;
---

<nav>
  {Object.entries(LOCALES).map(([code, label]) => (
    code === currentLocale
      ? <strong>{label}</strong>
      : <a href={`/${code}/`}>{label}</a>
  ))}
</nav>
