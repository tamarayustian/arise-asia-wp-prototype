---
import { Heart, Menu, X } from "lucide-react";
import { Icon } from "astro-icon/components";
import NavbarButton from "./NavbarButton.astro";

export interface Props {
  locale: string;
}

const { locale } = Astro.props;
const pathname = Astro.url.pathname;

interface NavItem {
  label: string;
  href: string;
  className?: string;
}

const navItems: NavItem[] = [
  { label: "About Us", href: `/${locale}/about` },
  { label: "Arise 2026", href: `/${locale}/arise26` },
  { label: "Upcoming Events", href: `/${locale}/upcoming-events` },
];

function isActive(href: string): boolean {
  if (href === `/${locale}/` || href === `/${locale}`) {
    return pathname === `/${locale}/` || pathname === `/${locale}`;
  }
  return pathname.startsWith(href);
}

const menuMainItems: NavItem[] = [
  { label: "Home", href: `/${locale}` },
  { label: "About Us", href: `/${locale}/about` },
  { label: "Countries", href: `/${locale}/countries` },
  { label: "Upcoming Events", href: `/${locale}/upcoming-events` },
  { label: "Take Action", href: `/${locale}/join` },
  { label: "Give", href: `/${locale}/give` },
  { label: "Arise Asia 2026", href: `/${locale}/arise26`, className: "text-gradient-accent" },
];

const menuSecondaryItems: NavItem[] = [
  { label: "Contact Us", href: `/${locale}/about/contact-us` },
];
---

<div class="fixed top-0 z-20 w-full overflow-visible pt-8 sm:pt-10 md:pt-14">
  <nav
    class="bg-accent-orange-lighter/50 relative z-10 container mx-auto flex w-11/12 max-w-93 items-center justify-between rounded-full px-5 py-4 shadow-2xl backdrop-blur-[200px] sm:max-w-176 sm:gap-4 sm:rounded-full lg:max-w-330 lg:gap-5 lg:rounded-full lg:px-7.5 lg:py-3"
  >
    <a href={`/${locale}/`} class="shrink-0">
      <img alt="Arise" class="h-10 w-auto lg:h-11" src="/logo-black-font.svg" />
    </a>

    <div class="flex items-center gap-6">
      <div id="desktop-nav-items" class="hidden items-center gap-6 lg:flex">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="group relative flex flex-col items-center"
            >
              <span
                class={`font-heading text-sm font-medium text-black transition-all hover:text-accent-orange-dark ${isActive(item.href) ? "font-semibold" : ""}`}
              >
                {item.label}
              </span>
              <span class=`bg-gradient-accent absolute bottom-0 left-1/2 h-0.5 w-full -translate-x-1/2 rounded-full ${isActive(item.href) ? "" : "hidden"}` />
            </a>
          ))
        }
      </div>

      <div id="desktop-donate-btn" class="hidden items-center lg:flex">
        <NavbarButton variant="filled" href={`/${locale}/give`}>
          Donate
          <Heart fill="currentColor" className="size-4" />
        </NavbarButton>
      </div>

      <button
        id="menu-btn"
        class="hover:text-accent-orange-dark flex shrink-0 text-gray-900 transition-opacity"
        aria-label="Toggle menu"
      >
        <span id="menu-hamburger"><Menu className="size-6" /></span>
        <span id="menu-close" class="hidden"><X className="size-6" /></span>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu-overlay"
    class="pointer-events-none invisible fixed inset-0 overflow-y-auto bg-white/60 opacity-0 backdrop-blur-[150px] transition-all duration-300"
  >
    <div
      id="mobile-menu-content"
      class="container mx-auto flex w-11/12 max-w-93 flex-col gap-8 pt-8 pb-12 text-black sm:max-w-176 sm:px-7.5 lg:max-w-330 lg:px-10"
    >
      <div class="flex flex-col gap-5">
        {
          menuMainItems.map((item) => (
            <a
              href={item.href}
              class={`font-heading hover:text-accent-orange-dark w-fit text-lg font-medium uppercase transition-all sm:text-xl ${item.className ?? ""} ${isActive(item.href) ? "text-accent-orange-dark font-semibold" : ""}`}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <div class="flex flex-col gap-2.5">
        {
          menuSecondaryItems.map((item) => (
            <a
              href={item.href}
              class={`font-heading text-accent-orange-darker hover:text-accent-blue-dark w-fit text-sm font-medium transition-all sm:text-base ${isActive(item.href) ? "text-accent-blue-dark font-semibold" : ""}`}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-4">
        <a
          href="#"
          class="text-accent-orange-darker hover:text-accent-blue-dark flex items-center justify-center transition-opacity"
          aria-label="X (Twitter)"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="fa6-brands:x-twitter" class="size-5" />
        </a>
        <a
          href="#"
          class="text-accent-orange-darker hover:text-accent-blue-dark flex items-center justify-center transition-opacity"
          aria-label="Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="fa6-brands:instagram" class="size-5" />
        </a>
        <a
          href="#"
          class="text-accent-orange-darker hover:text-accent-blue-dark flex items-center justify-center transition-opacity"
          aria-label="YouTube"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="fa6-brands:youtube" class="size-5" />
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleMenu(open) {
    const menuOverlay = document.getElementById("mobile-menu-overlay");
    const menuContent = document.getElementById("mobile-menu-content");
    const hamburger = document.getElementById("menu-hamburger");
    const closeIcon = document.getElementById("menu-close");

    const show = open ?? menuOverlay?.classList.contains("invisible");
    if (show) {
      const nav = document.querySelector("nav");
      const navBottom = nav?.getBoundingClientRect().bottom ?? 0;
      if (menuContent) menuContent.style.paddingTop = navBottom + 32 + "px";
      menuOverlay?.classList.remove(
        "invisible",
        "opacity-0",
        "pointer-events-none",
      );
      menuOverlay?.classList.add("opacity-100");
      const desktopNav = document.getElementById("desktop-nav-items");
      if (desktopNav) desktopNav.style.display = "none";
      const desktopDonate = document.getElementById("desktop-donate-btn");
      if (desktopDonate) desktopDonate.style.display = "none";
      hamburger?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    } else {
      menuOverlay?.classList.remove("opacity-100");
      menuOverlay?.classList.add(
        "invisible",
        "opacity-0",
        "pointer-events-none",
      );
      const desktopNav = document.getElementById("desktop-nav-items");
      if (desktopNav) desktopNav.style.display = "";
      const desktopDonate = document.getElementById("desktop-donate-btn");
      if (desktopDonate) desktopDonate.style.display = "";
      hamburger?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      document.body.style.overflow = "";
    }
  }

  function attachMenu() {
    const menuBtn = document.getElementById("menu-btn");
    if (menuBtn?.dataset._menuAttached) return;
    if (menuBtn) menuBtn.dataset._menuAttached = "1";
    const menuOverlay = document.getElementById("mobile-menu-overlay");
    const menuLinks = menuOverlay?.querySelectorAll("a");

    menuBtn?.addEventListener("click", () => toggleMenu());

    menuLinks?.forEach((link) => {
      link.addEventListener("click", () => toggleMenu(false));
    });

    menuOverlay?.addEventListener("click", (e) => {
      if (e.target === menuOverlay) toggleMenu(false);
    });
  }

  function updateActiveStates() {
    const path = window.location.pathname;

    function isActive(href) {
      const locale = path.split("/").filter(Boolean)[0] || "en";
      if (href.endsWith("/") || href === `/${locale}`) {
        return path === href || path === href.replace(/\/$/, "");
      }
      return path.startsWith(href);
    }

    document.querySelectorAll("#desktop-nav-items a").forEach((a) => {
      const href = a.getAttribute("href");
      const active = isActive(href);
      const span = a.querySelector("span");
      const underline = a.querySelector("[class*='bg-gradient-accent']");

      span?.classList.toggle("font-semibold", active);
      if (underline) underline.classList.toggle("hidden", !active);
    });

    document.querySelectorAll("#mobile-menu-content a").forEach((a) => {
      const href = a.getAttribute("href");
      const active = isActive(href);
      const isGradient = a.classList.contains("text-gradient-accent");
      if (!isGradient) {
        a.classList.toggle("text-accent-orange-dark", active);
      } else {
        a.style.color = active ? "var(--color-accent-orange-dark)" : "";
      }
      a.classList.toggle("font-semibold", active);
    });
  }

  attachMenu();
  updateActiveStates();
  document.addEventListener("astro:page-load", () => {
    attachMenu();
    updateActiveStates();
  });

  // Language panel (no-op if elements don't exist)
  const langBtn = document.getElementById("lang-btn");
  const langBtnMobile = document.getElementById("lang-btn-mobile");
  const langPanelWrapper = document.getElementById("lang-panel-wrapper");

  function toggleLang(e) {
    e.stopPropagation();
    langPanelWrapper?.classList.toggle("hidden");
  }

  function closeLang() {
    langPanelWrapper?.classList.add("hidden");
  }

  langBtn?.addEventListener("click", toggleLang);
  langBtnMobile?.addEventListener("click", toggleLang);

  document.addEventListener("click", (e) => {
    if (
      !langPanelWrapper?.classList.contains("hidden") &&
      !langBtn?.contains(e.target as Node) &&
      !langBtnMobile?.contains(e.target as Node) &&
      !langPanelWrapper?.contains(e.target as Node)
    ) {
      closeLang();
    }
  });
</script>
