---
import { Icon } from "astro-icon/components";

export interface Props {
  locale: string;
}

const { locale } = Astro.props;
---

<div class="fixed z-20 w-full overflow-visible pt-12">
  <nav
    class="relative container mx-auto flex w-11/12 max-w-6xl items-center overflow-visible rounded-full bg-black/75 px-6 shadow-2xl"
  >
    <a href={`/${locale}/`} class="-my-4">
      <img
        alt="Arise logo"
        class="my-2 size-16 sm:size-20 lg:hover:size-24"
        src="/logo.svg"
      />
    </a>

    <div
      class="hidden lg:absolute lg:left-1/2 lg:flex lg:-translate-x-1/2 lg:gap-6"
    >
      <a href={`/${locale}/`} class="font-heading py-4 text-white">
        <div class="group relative w-fit">
          <p>Home</p>
          <span
            class="absolute hidden h-0.5 w-full bg-linear-to-r from-yellow-500 to-red-500 group-hover:block"
          ></span>
        </div>
      </a>
      <a href={`/${locale}/about`} class="font-heading py-4 text-white">
        <div class="group relative w-fit">
          <p>About Us</p>
          <span
            class="absolute hidden h-0.5 w-full bg-linear-to-r from-yellow-500 to-red-500 group-hover:block"
          ></span>
        </div>
      </a>
      <a href={`/${locale}/movements`} class="font-heading py-4 text-white">
        <div class="group relative w-fit">
          <p>Movements</p>
          <span
            class="absolute hidden h-0.5 w-full bg-linear-to-r from-yellow-500 to-red-500 group-hover:block"
          ></span>
        </div>
      </a>
    </div>

    <div class="hidden lg:ml-auto lg:flex lg:items-center lg:gap-3">
      <a
        href="mailto:info@ariseasia.org"
        class="font-heading inline-flex items-center gap-1.5 rounded-full border border-yellow-500 px-3 py-1 text-sm text-white transition hover:bg-yellow-500/20"
        >Contact Us<Icon name="lucide:arrow-up-right" class="size-3.5" /></a
      >
      <a
        href="https://www.totalideas.org/projects"
        rel="noopener noreferrer"
        target="_blank"
        class="font-heading inline-flex items-center gap-1.5 rounded-full bg-yellow-500 px-3 py-1 text-sm text-white transition hover:bg-yellow-600"
        >Donate<Icon name="fa6-solid:heart" class="size-3.5" /></a
      >
    </div>

    <div class="my-auto ml-auto flex text-white lg:hidden">
      <button id="menu-btn" class="size-8" aria-label="Toggle menu">
        <svg stroke="currentColor" viewBox="0 0 12 12" class="size-8">
          <path d="M2 3H12M2 6H12M2 9H12"></path>
        </svg>
      </button>
    </div>
  </nav>

  <ul
    id="mobile-menu"
    class="container mx-auto mt-2 hidden w-11/12 max-w-4xl list-none rounded-xl bg-black/75 p-4 shadow-2xl lg:hidden"
  >
    <li class="py-2">
      <a
        href={`/${locale}/`}
        class="font-heading text-white decoration-orange-500 underline-offset-4 hover:underline"
        >Home</a
      >
    </li>
    <li class="py-2">
      <a
        href={`/${locale}/about`}
        class="font-heading text-white decoration-orange-500 underline-offset-4 hover:underline"
        >About Us</a
      >
    </li>
    <li class="py-2">
      <a
        href={`/${locale}/movements`}
        class="font-heading text-white decoration-orange-500 underline-offset-4 hover:underline"
        >Movements</a
      >
    </li>
    <li class="py-2">
      <a
        href="mailto:info@ariseasia.org"
        class="font-heading text-white decoration-orange-500 underline-offset-4 hover:underline"
        rel="noopener noreferrer"
        target="_blank">Contact us</a
      >
    </li>
    <li class="py-2">
      <a
        href="https://www.totalideas.org/projects"
        class="font-heading text-white decoration-orange-500 underline-offset-4 hover:underline"
        rel="noopener noreferrer"
        target="_blank">Donate</a
      >
    </li>
  </ul>
</div>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
</script>
