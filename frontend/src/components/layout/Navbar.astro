---
import { Heart, Menu, X } from "lucide-react";
import { Icon } from "astro-icon/components";
import NavbarButton from "./NavbarButton.astro";

export interface Props {
  locale: string;
}

const { locale } = Astro.props;
const pathname = Astro.url.pathname;

interface NavItem {
  label: string;
  href: string;
}

const navItems: NavItem[] = [
  { label: "About Us", href: `/${locale}/about` },
  { label: "Arise 2026", href: `/${locale}/` },
  { label: "Upcoming Events", href: `/${locale}/upcoming-events` },
];

function isActive(href: string): boolean {
  if (href === `/${locale}/`) {
    return pathname === `/${locale}/` || pathname === `/${locale}`;
  }
  return pathname.startsWith(href);
}

const menuMainItems: NavItem[] = [
    { label: "Home", href: `/${locale}` },
  { label: "About Us", href: `/${locale}/about` },
  { label: "Countries", href: `/${locale}/` },
  { label: "Upcoming Events", href: `/${locale}/` },
  { label: "Take Action", href: `/${locale}/` },
    { label: "Give", href: `/${locale}/give` },
  { label: "Arise Asia 2026", href: `/${locale}/give` },
];

const menuSecondaryItems: NavItem[] = [
  { label: "Contact Us", href: `/${locale}/about/` },
];
---

<div class="fixed top-0 z-20 w-full overflow-visible pt-8 sm:pt-10 md:pt-14">
  <nav
    class="relative z-10 bg-accent-orange-lighter/30 container mx-auto flex w-11/12 max-w-93 items-center justify-between rounded-full px-5 py-4 shadow-2xl backdrop-blur-2xl sm:max-w-176 sm:gap-4 sm:rounded-full lg:max-w-330 lg:gap-5 lg:rounded-full lg:px-7.5 lg:py-3"
  >
    <a href={`/${locale}/`} class="shrink-0">
      <img
        alt="Arise"
        class="h-10 w-auto lg:h-11"
        src="/logo-black-font.svg"
      />
    </a>

    <div class="flex items-center gap-6">
      <div id="desktop-nav-items" class="hidden items-center gap-6 lg:flex">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="group relative flex flex-col items-center"
            >
              <span
                class={`font-heading text-sm font-medium text-black ${isActive(item.href) ? "font-semibold" : ""}`}
              >
                {item.label}
              </span>
              {isActive(item.href) && (
                <span class="bg-gradient-accent absolute bottom-0 left-1/2 h-0.5 w-full -translate-x-1/2 rounded-full" />
              )}
            </a>
          ))
        }
      </div>

      <div id="desktop-donate-btn" class="hidden items-center lg:flex">
        <NavbarButton variant="filled" href={`/${locale}/give`}>
          Donate
          <Heart fill="currentColor" className="size-4" />
        </NavbarButton>
      </div>

      <button
        id="menu-btn"
        class="hover:text-accent-orange-dark flex shrink-0 text-gray-900 transition-opacity"
        aria-label="Toggle menu"
      >
        <span id="menu-hamburger"><Menu className="size-6" /></span>
        <span id="menu-close" class="hidden"><X className="size-6" /></span>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu-overlay"
    class="fixed inset-0 overflow-y-auto bg-white/30 backdrop-blur-[100px] transition-all duration-300 invisible opacity-0 pointer-events-none"
  >
    <div
      id="mobile-menu-content"
      class="container mx-auto flex w-11/12 max-w-93 flex-col gap-8 pt-8 pb-12 sm:max-w-176 sm:px-7.5 lg:max-w-330 lg:px-10"
    >
      <div class="flex flex-col gap-5">
        {
          menuMainItems.map((item) => (
            <a
              href={item.href}
              class={`font-heading w-fit font-medium text-black text-lg sm:text-xl transition-all uppercase ${isActive(item.href) ? "font-semibold" : ""}`}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <div class="flex flex-col gap-2.5">
        {
          menuSecondaryItems.map((item) => (
            <a
              href={item.href}
              class={`font-heading w-fit text-sm sm:text-base font-medium text-accent-orange-darker transition-all hover:opacity-60 ${isActive(item.href) ? "font-semibold text-black" : ""}`}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-4">
        <a
          href="#"
          class="flex items-center justify-center text-accent-orange-darker transition-opacity hover:opacity-60"
          aria-label="X (Twitter)"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="fa6-brands:x-twitter" class="size-5" />
        </a>
        <a
          href="#"
          class="flex items-center justify-center text-accent-orange-darker transition-opacity hover:opacity-60"
          aria-label="Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="fa6-brands:instagram" class="size-5" />
        </a>
        <a
          href="#"
          class="flex items-center justify-center text-accent-orange-darker transition-opacity hover:opacity-60"
          aria-label="YouTube"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Icon name="fa6-brands:youtube" class="size-5" />
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const menuBtn = document.getElementById("menu-btn");
  const hamburger = document.getElementById("menu-hamburger");
  const closeIcon = document.getElementById("menu-close");
  const menuOverlay = document.getElementById("mobile-menu-overlay");
  const menuLinks = menuOverlay?.querySelectorAll("a");

  function toggleMenu(open) {
    const show = open ?? menuOverlay?.classList.contains("invisible");
    if (show) {
      const menuContent = document.getElementById("mobile-menu-content");
      const nav = document.querySelector("nav");
      const navBottom = nav?.getBoundingClientRect().bottom ?? 0;
      if (menuContent) menuContent.style.paddingTop = (navBottom + 32) + "px";
      menuOverlay?.classList.remove("invisible", "opacity-0", "pointer-events-none");
      menuOverlay?.classList.add("opacity-100");
      const desktopNav = document.getElementById("desktop-nav-items");
      if (desktopNav) desktopNav.style.display = "none";
      const desktopDonate = document.getElementById("desktop-donate-btn");
      if (desktopDonate) desktopDonate.style.display = "none";
      hamburger?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    } else {
      menuOverlay?.classList.remove("opacity-100");
      menuOverlay?.classList.add("invisible", "opacity-0", "pointer-events-none");
      const desktopNav = document.getElementById("desktop-nav-items");
      if (desktopNav) desktopNav.style.display = "";
      const desktopDonate = document.getElementById("desktop-donate-btn");
      if (desktopDonate) desktopDonate.style.display = "";
      hamburger?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      document.body.style.overflow = "";
    }
  }

  menuBtn?.addEventListener("click", () => toggleMenu());

  menuLinks?.forEach((link) => {
    link.addEventListener("click", () => toggleMenu(false));
  });

  menuOverlay?.addEventListener("click", (e) => {
    if (e.target === menuOverlay) toggleMenu(false);
  });

  const langBtn = document.getElementById("lang-btn");
  const langBtnMobile = document.getElementById("lang-btn-mobile");
  const langPanelWrapper = document.getElementById("lang-panel-wrapper");
  const langPanel = document.getElementById("lang-panel");
  const langOptions = langPanel?.querySelectorAll("button");

  function toggleLang(e) {
    e.stopPropagation();
    langPanelWrapper?.classList.toggle("hidden");
  }

  function closeLang() {
    langPanelWrapper?.classList.add("hidden");
  }

  langBtn?.addEventListener("click", toggleLang);
  langBtnMobile?.addEventListener("click", toggleLang);

  langOptions?.forEach((opt) => {
    opt.addEventListener("click", closeLang);
  });

  document.addEventListener("click", (e) => {
    if (
      !langPanelWrapper?.classList.contains("hidden") &&
      !langBtn?.contains(e.target as Node) &&
      !langBtnMobile?.contains(e.target as Node) &&
      !langPanelWrapper?.contains(e.target as Node)
    ) {
      closeLang();
    }
  });
</script>
