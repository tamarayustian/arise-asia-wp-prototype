---
import { Icon } from 'astro-icon/components';

export interface Props {
  locale: string;
}

const { locale } = Astro.props;
---

<div class="fixed z-20 pt-16 w-full overflow-visible">
  <nav class="container flex items-center mx-auto w-11/12 max-w-6xl rounded-full shadow-2xl bg-black/75 px-6 overflow-visible relative">
    <a href={`/${locale}/`} class="-my-4">
      <img alt="Arise logo" class="my-2 size-16 sm:size-20 lg:hover:size-24" src="/logo.svg" />
    </a>

    <div class="hidden lg:absolute lg:left-1/2 lg:-translate-x-1/2 lg:flex lg:gap-6">
      <a href={`/${locale}/`} class="py-4 text-white font-heading">
        <div class="relative w-fit group">
          <p>Home</p>
          <span class="hidden absolute w-full h-0.5 bg-linear-to-r from-yellow-500 to-red-500 group-hover:block"></span>
        </div>
      </a>
      <a href={`/${locale}/about`} class="py-4 text-white font-heading">
        <div class="relative w-fit group">
          <p>About Us</p>
          <span class="hidden absolute w-full h-0.5 bg-linear-to-r from-yellow-500 to-red-500 group-hover:block"></span>
        </div>
      </a>
      <a href={`/${locale}/movements`} class="py-4 text-white font-heading">
        <div class="relative w-fit group">
          <p>Movements</p>
          <span class="hidden absolute w-full h-0.5 bg-linear-to-r from-yellow-500 to-red-500 group-hover:block"></span>
        </div>
      </a>
    </div>

    <div class="hidden lg:flex lg:items-center lg:gap-3 lg:ml-auto">
      <a href="mailto:info@ariseasia.org" class="px-3 py-1 text-white font-heading text-sm rounded-full border border-yellow-500 hover:bg-yellow-500/20 transition inline-flex items-center gap-1.5">Contact Us<Icon name="lucide:arrow-up-right" class="size-3.5" /></a>
      <a href="https://www.totalideas.org/projects" rel="noopener noreferrer" target="_blank" class="px-3 py-1 text-white font-heading text-sm rounded-full bg-yellow-500 hover:bg-yellow-600 transition inline-flex items-center gap-1.5">Donate<Icon name="fa6-solid:heart" class="size-3.5" /></a>
    </div>

    <div class="flex my-auto text-white lg:hidden ml-auto">
      <button id="menu-btn" class="size-8" aria-label="Toggle menu">
        <svg stroke="currentColor" viewBox="0 0 12 12" class="size-8">
          <path d="M2 3H12M2 6H12M2 9H12"></path>
        </svg>
      </button>
    </div>
  </nav>

  <ul id="mobile-menu" class="hidden container mx-auto mt-2 w-11/12 max-w-4xl rounded-xl shadow-2xl bg-black/75 p-4 list-none lg:hidden">
    <li class="py-2"><a href={`/${locale}/`} class="text-white hover:underline font-heading underline-offset-4 decoration-orange-500">Home</a></li>
    <li class="py-2"><a href={`/${locale}/about`} class="text-white hover:underline font-heading underline-offset-4 decoration-orange-500">About Us</a></li>
    <li class="py-2"><a href={`/${locale}/movements`} class="text-white hover:underline font-heading underline-offset-4 decoration-orange-500">Movements</a></li>
    <li class="py-2"><a href="mailto:info@ariseasia.org" class="text-white hover:underline font-heading underline-offset-4 decoration-orange-500" rel="noopener noreferrer" target="_blank">Contact us</a></li>
    <li class="py-2"><a href="https://www.totalideas.org/projects" class="text-white hover:underline font-heading underline-offset-4 decoration-orange-500" rel="noopener noreferrer" target="_blank">Donate</a></li>
  </ul>
</div>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
