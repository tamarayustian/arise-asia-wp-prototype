---
import { Icon } from "astro-icon/components";

export interface Props {
  locale: string;
}

const { locale } = Astro.props;

interface NavItem {
  label: string;
  href: string;
}

const footerNavItems: NavItem[] = [
  { label: "Home", href: `/${locale}/` },
  { label: "About Us", href: `/${locale}/about` },
  { label: "Arise Asia 2026", href: `/${locale}/arise26` },
  { label: "Upcoming Events", href: `/${locale}/upcoming-events` },
  { label: "Donate", href: `/${locale}/give` },
];

const mobileCol1: NavItem[] = [
  footerNavItems[0],
  footerNavItems[1],
  footerNavItems[4],
];
const mobileCol2: NavItem[] = [footerNavItems[2], footerNavItems[3]];
---

<footer class="relative overflow-visible bg-blue-50">
  <p
    class="font-heading pointer-events-none absolute inset-0 flex items-center justify-center overflow-hidden font-semibold text-blue-600 uppercase opacity-[0.07] select-none"
    aria-hidden="true"
  >
    <span
      class="text-center text-[clamp(160px,20vw,262px)] leading-[0.75] tracking-[-0.09em] md:whitespace-nowrap"
    >
      <span class="block md:inline">Arise</span>
      <span class="block md:inline">Asia</span>
    </span>
  </p>
  <div class="container-page relative z-10 px-8 py-12 sm:px-14 lg:px-16">
    <div class="flex flex-col justify-between md:flex-row md:items-center">
      <div class="flex flex-col items-start gap-7">
        <img
          alt="Arise Asia"
          class="h-10 w-auto md:h-14"
          src="/logos/wordmark-black.svg"
        />

        <div class="mb-6 flex items-center gap-x-3 md:gap-x-4">
          <a
            href="https://www.instagram.com/ariseasia.movement"
            rel="noopener noreferrer"
            target="_blank"
          >
            <Icon
              name="fa6-brands:instagram"
              class="size-5 text-[#595959] hover:text-yellow-500"
            />
          </a>
          <a
            href="https://www.youtube.com/@AriseAsiaMovement"
            rel="noopener noreferrer"
            target="_blank"
          >
            <Icon
              name="fa6-brands:youtube"
              class="size-5 text-[#595959] hover:text-red-500"
            />
          </a>
          <a
            href="https://www.facebook.com/ariseasia2023"
            rel="noopener noreferrer"
            target="_blank"
          >
            <Icon
              name="fa6-brands:facebook"
              class="size-5 text-[#595959] hover:text-blue-500"
            />
          </a>
          <a
            href={`/${locale}/about/contact-us`}
            class="font-heading text-sm text-[#595959] hover:text-blue-600"
          >
            Contact Us
          </a>
        </div>
      </div>

      <div class="flex flex-col gap-7">
        <div class="flex flex-row gap-17.5 md:hidden">
          <nav class="flex flex-col gap-2.5">
            {
              mobileCol1.map((item) => (
                <a
                  href={item.href}
                  class="font-semibold uppercase hover:text-blue-600"
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
          <nav class="flex flex-col gap-2.5">
            {
              mobileCol2.map((item) => (
                <a
                  href={item.href}
                  class="font-semibold uppercase hover:text-blue-600"
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
        <nav class="hidden gap-4 md:flex lg:gap-5 xl:gap-7.5">
          {
            footerNavItems.map((item) => (
              <a
                href={item.href}
                class="text-center font-semibold uppercase hover:text-blue-600"
              >
                {item.label}
              </a>
            ))
          }
        </nav>

        <p class="text-xs text-[#909090] italic md:text-right">
          Copyright &copy;2026 Arise Asia. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
