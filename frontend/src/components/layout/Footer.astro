---
import { Icon } from "astro-icon/components";

export interface Props {
  locale: string;
}

const { locale } = Astro.props;
---

<footer class="relative overflow-visible bg-blue-50">
  <p
    class="font-heading pointer-events-none absolute inset-0 flex items-center justify-center overflow-hidden font-semibold text-blue-600 uppercase opacity-[0.07] select-none"
    aria-hidden="true"
  >
    <span
      class="text-center text-[clamp(160px,20vw,262px)] leading-[0.75] tracking-[-0.09em] md:whitespace-nowrap"
    >
      <span class="block md:inline">Arise</span>
      <span class="block md:inline">Asia</span>
    </span>
  </p>
  <div class="relative z-10 container-page px-8 py-12 sm:px-14 lg:px-16">
    <div class="flex flex-col justify-between md:flex-row md:items-center">
      <div class="flex flex-col gap-7 items-start">
        <img alt="Arise Asia" class="h-10 w-auto md:h-14" src="/wordmark-black.svg" />

        <div class="mb-6 flex items-center gap-x-3 md:gap-x-4">
          <a
            href="https://www.instagram.com/ariseasia.movement"
            rel="noopener noreferrer"
            target="_blank"
          >
            <Icon
              name="fa6-brands:instagram"
              class="text-[#595959] hover:text-yellow-500 size-5"
            />
          </a>
          <a
            href="https://www.youtube.com/@AriseAsiaMovement"
            rel="noopener noreferrer"
            target="_blank"
          >
            <Icon
              name="fa6-brands:youtube"
              class="text-[#595959] hover:text-red-500 size-5"
            />
          </a>
          <a
            href="https://www.facebook.com/ariseasia2023"
            rel="noopener noreferrer"
            target="_blank"
          >
            <Icon
              name="fa6-brands:facebook"
              class="text-[#595959] hover:text-blue-500 size-5"
            />
          </a>
          <a
            href={`/${locale}/about/contact-us`}
            class="font-heading text-sm text-[#595959] hover:text-blue-600"
          >
            Contact Us
          </a>
        </div>
      </div>

      <div class="flex flex-col gap-7">
        <div class="flex flex-row gap-17.5 md:hidden">
          <nav class="flex flex-col gap-2.5">
            <a
              href={`/${locale}/`}
              class="uppercase font-semibold hover:text-blue-600">Home</a
            >
            <a
              href={`/${locale}/about`}
              class="uppercase font-semibold hover:text-blue-600">About Us</a
            >
            <a
              href={`/${locale}/give`}
              class="uppercase font-semibold hover:text-blue-600">Donate</a
            >
          </nav>
          <nav class="flex flex-col gap-2.5">
            <a
              href={`/${locale}/arise26`}
              class="uppercase font-semibold hover:text-blue-600">Arise Asia 2026</a
            >
            <a
              href={`/${locale}/upcoming-events`}
              class="uppercase font-semibold hover:text-blue-600">Upcoming Events</a
            >
          </nav>
        </div>
        <nav class="hidden gap-4 lg:gap-5 xl:gap-7.5 md:flex">
          <a
            href={`/${locale}/`}
            class="uppercase text-center font-semibold hover:text-blue-600">Home</a
          >
          <a
            href={`/${locale}/about`}
            class="uppercase text-center font-semibold hover:text-blue-600">About Us</a
          >
          <a
            href={`/${locale}/arise26`}
            class="uppercase text-center font-semibold hover:text-blue-600">Arise Asia 2026</a
          >
          <a
            href={`/${locale}/upcoming-events`}
            class="uppercase text-center font-semibold hover:text-blue-600">Upcoming Events</a
          >
          <a
            href={`/${locale}/give`}
            class="uppercase text-center font-semibold hover:text-blue-600">Donate</a
          >
        </nav>

        <p class="text-xs italic text-[#909090] md:text-right">
          Copyright &copy;2026 Arise Asia. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>
