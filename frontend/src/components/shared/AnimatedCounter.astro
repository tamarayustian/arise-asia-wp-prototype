---
interface Props {
  target: number;
}

const { target } = Astro.props;
---

<span data-animated-counter={target}>0</span>

<script is:inline>
  // Wait for DOM, then observe all counter elements
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue; // skip until visible
          const el = entry.target;
          observer.unobserve(el); // animate once

          const target = parseInt(el.dataset.animatedCounter || "0");
          // Duration scales with target: 300ms–1000ms
          const duration = Math.min(1000, Math.max(300, 1000 * (target / 100)));
          const startTime = performance.now();

          function tick(now) {
            const elapsed = now - startTime;
            const p = Math.min(1, elapsed / duration);
            el.textContent = Math.floor(p * target).toString();

            if (elapsed < duration) requestAnimationFrame(tick);
            else el.textContent = target.toString();
          }

          requestAnimationFrame(tick);
        }
      },
      { threshold: 0 },
    );

    document
      .querySelectorAll("[data-animated-counter]")
      .forEach((el) => observer.observe(el));
  });
</script>
